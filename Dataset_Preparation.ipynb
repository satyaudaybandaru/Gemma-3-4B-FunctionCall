      "cell_type": "markdown",
      "source": [
        "#### Initialize New chat template"
      ],
      "metadata": {
        "id": "IvHRnebDlP6-"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "We now use the `Gemma-3` format for conversation style finetunes.\n",
        "\n",
        "Gemma-3 original chat template:\n",
        "\n",
        "```\n",
        "<bos><start_of_turn>user\n",
        "Hello!<end_of_turn>\n",
        "<start_of_turn>model\n",
        "Hey there!<end_of_turn>\n",
        "```\n"
      ],
      "metadata": {
        "id": "PNGGOZZCl5ta"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from unsloth import FastModel\n",
        "\n",
        "model, tokenizer = FastModel.from_pretrained(\n",
        "    model_name = \"unsloth/gemma-3-4b-it\",\n",
        "    max_seq_length = 4096, # Choose any for long context!\n",
        "    load_in_4bit = True,  # 4 bit quantization to reduce memory\n",
        "    load_in_8bit = False, # [NEW!] A bit more accurate, uses 2x memory\n",
        "    full_finetuning = False, # [NEW!] We have full finetuning now!\n",
        "    # token = \"YOUR_HF_TOKEN\", # HF Token for gated models\n",
        ")"
      ],
      "metadata": {
        "id": "4AsQElxYoOaA"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "tool_calls_template = '''{{ bos_token }}\n",
        "{% macro render_content(content) %}\n",
        "    {% if content is string %}\n",
        "{{ content }}\n",
        "    {% elif content is iterable %}\n",
        "        {% for part in content %}\n",
        "            {% if part[\"type\"] == \"text\" %}\n",
        "{{ part[\"text\"] }}\n",
        "            {% endif %}\n",
        "        {% endfor %}\n",
        "    {% endif %}\n",
        "{% endmacro %}\n",
        "\n",
        "{%- for message in messages %}\n",
        "    {%- if message[\"role\"] == \"system\" %}\n",
        "<start_of_turn>system\n",
        "{{ render_content(message[\"content\"]) }}\n",
        "\n",
        "        {%- if tools %}\n",
        "You have access to the following tools:\n",
        "<tools>\n",
        "{{ tools | tojson }}\n",
        "</tools>\n",
        "        {%- endif %}\n",
        "<end_of_turn>\n",
        "    {%- endif %}\n",
        "{%- endfor %}\n",
        "\n",
        "{%- for message in messages %}\n",
        "\n",
        "    {%- if message[\"role\"] == \"user\" %}\n",
        "\n",
        "<start_of_turn>user\n",
        "{{ render_content(message[\"content\"]) }}\n",
        "<end_of_turn>\n",
        "\n",
        "    {%- elif message[\"role\"] == \"assistant\" and message.get(\"tool_calls\") %}\n",
        "\n",
        "<start_of_turn>model\n",
        "<tool_call>\n",
        "{{ message[\"tool_calls\"] | map(attribute=\"function\") | list | tojson }}\n",
        "</tool_call>\n",
        "<end_of_turn>\n",
        "\n",
        "    {%- elif message[\"role\"] == \"tool\" %}\n",
        "\n",
        "<start_of_turn>tool\n",
        "<tool_response>\n",
        "{{ render_content(message[\"content\"]) }}\n",
        "</tool_response>\n",
        "<end_of_turn>\n",
        "\n",
        "    {%- elif message[\"role\"] == \"assistant\" %}\n",
        "\n",
        "<start_of_turn>model\n",
        "{{ render_content(message[\"content\"]) }}\n",
        "<end_of_turn>\n",
        "\n",
        "    {%- endif %}\n",
        "\n",
        "{%- endfor %}\n",
        "\n",
        "{% if add_generation_prompt %}\n",
        "<start_of_turn>model\n",
        "{% endif %}\n",
        "'''\n",
        "\n",
        "eos_token = tokenizer.eos_token"
      ],
      "metadata": {
        "id": "k_rSnpFuFa7l"
      },
      "execution_count": null,
      "outputs": []
    },
