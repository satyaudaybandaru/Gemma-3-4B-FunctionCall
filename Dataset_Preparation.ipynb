        "        ).removeprefix('<bos>')\n",
        "\n",
        "        all_texts.append(rendered_text)\n",
        "\n",
        "    return {\"text\": all_texts}\n",
        "\n",
        "\n",
        "dataset = datasets.map(convert_to_unsloth_tool_format, batched=True)"
      ]
